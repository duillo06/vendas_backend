DJANGO_ENV=development
SECRET_KEY=dev-insecure-change-me
DEBUG=True

# API local: python manage.py runserver 8001
# (8000 reservada para o projeto principal)

POSTGRES_DB=foodservice
POSTGRES_USER=foodservice
POSTGRES_PASSWORD=foodservice
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

APP_VERSION=1.0.0
MEDIA_PUBLIC_BASE_URL=
# true = API devolve /media/... (recomendado com Vite proxy / LAN)
MEDIA_USE_RELATIVE_URLS=true
