# Copie para .env.production e preencha os valores reais.
# NUNCA commite .env.production com secrets.

DJANGO_ENV=production
SECRET_KEY=troque-por-uma-chave-segura-aleatoria
DEBUG=False

# Hosts separados por vírgula (inclua api, admin e wildcard lógico via middleware)
ALLOWED_HOSTS=.foodservice.app,api.foodservice.app,admin.foodservice.app

POSTGRES_DB=foodservice
POSTGRES_USER=foodservice
POSTGRES_PASSWORD=troque-a-senha-do-banco
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS — origens explícitas (regex cobre subdomínios de tenant)
CORS_ALLOWED_ORIGINS=https://admin.foodservice.app,https://api.foodservice.app

STOREFRONT_BASE_DOMAIN=foodservice.app
APP_VERSION=1.0.0

# E-mail (confirmação de pedido via Celery)
DEFAULT_FROM_EMAIL=noreply@foodservice.app
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=sua-api-key-sendgrid
EMAIL_USE_TLS=true

# Opcional — monitoramento de erros
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# TLS terminado no Nginx/Traefik — manter true em produção
SECURE_SSL_REDIRECT=true
